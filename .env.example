# ─────────────────────────────────────────────────────────────────────────
# Henri — variables d'environnement
# Copier en `.env.local` pour le dev local, et configurer les mêmes valeurs
# dans Vercel (Project Settings → Environment Variables) pour la prod.
# ─────────────────────────────────────────────────────────────────────────

# ── Firebase Web (CLIENT, exposé au navigateur) ──────────────────────────
# Valeurs publiques (clés web Firebase). Des valeurs de repli existent déjà
# dans src/lib/firebase.ts (projet henri-11598), mais il est préférable de
# les définir explicitement sur Vercel.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Notifications push (FCM Web Push) ────────────────────────────────────
# OBLIGATOIRE pour les notifs push : AUCUN repli en dur. Sans cette clé,
# les notifications push ne fonctionnent pas (messaging.ts).
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Firebase Admin (SERVEUR, secret — routes /api/admin/*, cron, invites) ─
# Service account : Firebase Console → Project Settings → Service accounts →
# Generate new private key. La clé privée contient des \n littéraux — les
# garder tels quels (le code remplace \\n par de vrais retours à la ligne).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Brevo (emails : invitations, reset password) ─────────────────────────
BREVO_API_KEY=

# ── Cron Vercel (nettoyage des dossiers archivés) ────────────────────────
# Protège la route /api/cron/cleanup-archived. Vercel envoie automatiquement
# l'en-tête Authorization: Bearer <CRON_SECRET> aux crons déclarés dans
# vercel.json si cette variable est définie.
CRON_SECRET=
